# ─────────────────────────────────────────────────────────────────────────────
# KrishiSetu Backend — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in your real values.
# .env is git-ignored; .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

FLASK_SECRET_KEY=change-me-to-something-random-in-production

MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=agriculture_db
MYSQL_PORT=3306

# Gmail SMTP — App Password required (NOT your normal Gmail password).
# Setup: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_ADDRESS=nidhishree615@gmail.com
EMAIL_PASSWORD=vxpb ymxq msqh isyx

OTP_EXPIRY_MINUTES=5

# Uncomment to skip SMTP during local testing (OTP still stored in DB).
# SKIP_EMAIL_SEND=1

# Uncomment to print OTP to Flask console (dev only — never use in production).
# OTP_DEBUG=1

# GROQ_API_KEY=your_groq_api_key_here
